{
  "name": "spoonsketch-telegram-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Telegram bot for Spoon & Sketch — receives recipe URLs / screenshots and pipes them through the extract-recipe Edge Function.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "bullmq": "^5.34.10",
    "ioredis": "^5.4.1",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
